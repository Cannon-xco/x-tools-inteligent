# ============================================================
# XTools Intelligent — Environment Variables
# Copy this file to .env.local for local development.
# Set these directly in Railway Dashboard > Variables.
# ============================================================

# ── Database (REQUIRED) ──────────────────────────────────────
# Railway: Add PostgreSQL plugin → copy DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI / Outreach Generation (REQUIRED) ─────────────────────
# Get key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use for outreach generation (optional, default shown)
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# ── Server Actions — CSRF Origin Whitelist (REQUIRED on Railway) ──
# Set to your Railway app domain (no https://, no trailing slash)
# Multiple domains: comma-separated
# Example: my-app.up.railway.app,www.mysite.com
ALLOWED_ORIGINS=my-app.up.railway.app

# ── Enrichment Tuning (OPTIONAL) ────────────────────────────
# Timeout per enrichment source in ms (default: 12000)
ENRICHMENT_TIMEOUT_MS=12000

# Set to "false" to disable Playwright fallback (faster, less accurate)
ENRICHMENT_USE_PLAYWRIGHT=true

# Max concurrent leads for batch enrichment (default: 5)
MAX_CONCURRENT_ENRICHMENT=5

# ── Redis / Queue (OPTIONAL — for future BullMQ upgrade) ────
# Railway: Add Redis plugin → REDIS_URL is set automatically
# Leave empty to use in-memory queue (fine for single-instance)
# REDIS_URL=redis://default:password@host:6379

# ── Node / Next.js (set automatically by Railway) ───────────
# NODE_ENV=production
# PORT=3000
