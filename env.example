# ============================================================
# XTools Intelligent — Environment Variables Template
# ============================================================
# HOW TO USE:
#   Local dev  → copy this file to .env.local, fill in real values
#   Railway    → set each variable in Dashboard > Variables
#
# DO NOT commit .env.local to git — it is already in .gitignore
# ============================================================

# ── Database (REQUIRED) ──────────────────────────────────────
# Local: use Docker Compose PostgreSQL or local PostgreSQL
# Railway: add PostgreSQL plugin → DATABASE_URL is set automatically
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ── AI / Outreach Generation (REQUIRED) ─────────────────────
# Get your key at https://openrouter.ai/keys
# Free models available — see https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used for outreach email generation (optional, default shown below)
# Free options: z-ai/glm-4.5-air:free | arcee-ai/trinity-large-preview:free
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# ── Email Sending — Resend (REQUIRED for Send Email feature) ─
# Sign up at https://resend.com → Settings → API Keys → Create API Key
# Free tier: 3,000 emails/month, 100/day — no credit card required
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address shown in recipient inbox
# Testing: use onboarding@resend.dev (no domain verification needed)
# Production: use your verified domain e.g. outreach@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# Display name shown in recipient inbox
RESEND_FROM_NAME=XTools Outreach

# ── Server Actions — CSRF Origin Whitelist (REQUIRED on Railway) ──
# Set to your Railway app domain, no https://, no trailing slash
# Multiple domains: comma-separated
ALLOWED_ORIGINS=my-app.up.railway.app

# ── Enrichment Tuning (OPTIONAL) ────────────────────────────
# Timeout per enrichment source adapter in ms (default: 12000)
ENRICHMENT_TIMEOUT_MS=12000

# Set to "false" to disable Playwright browser fallback (faster, less accurate)
ENRICHMENT_USE_PLAYWRIGHT=true

# Max concurrent leads processed in batch enrichment (default: 5)
MAX_CONCURRENT_ENRICHMENT=5

# ── Redis / Queue (OPTIONAL — BullMQ upgrade) ────────────────
# Railway: add Redis plugin → REDIS_URL is set automatically
# Without this, an in-memory queue is used (fine for single-instance)
# REDIS_URL=redis://default:password@host:6379

# ── Node / Next.js (set automatically by Railway) ───────────
# NODE_ENV=production
# PORT=3000
