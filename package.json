    "next-auth": "^5.0.0-beta.30",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "playwright": "^1.48.0",
    "playwright-core": "^1.48.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.11.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
